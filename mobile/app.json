{
  "expo": {
    "name": "RideBuddy",
    "slug": "ridebuddy",
    "version": "1.0.0",
    "scheme": "ridebuddy",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sujal.ridebuddy"
    },
    "android": {
      "package": "com.sujal.ridebuddy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "eas": {
        "projectId": "4250b61c-79b4-44c6-8aee-0027314c2e2d"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "sk.your-download-token-here",
          "RNMapboxMapsVersion": "11.0.0"
        }
      ]
    ]
  }
}
